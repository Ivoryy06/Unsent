# Gemini API key — only needed in web mode (no local backend).
# In local mode the backend reads this from its own environment.
VITE_GEMINI_API_KEY=

# Set to your backend URL in local mode, e.g. http://localhost:5051
# Leave empty to run in web mode (Gemini called directly from the browser).
VITE_API_BASE=

# Set to "true" to force web mode even if VITE_API_BASE is set.
VITE_WEB_MODE=false
